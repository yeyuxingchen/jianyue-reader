{
  "name": "jianyue-reader",
  "version": "1.0.0",
  "description": "简阅 - 本地电子书阅读器",
  "author": "jianyue",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "cross-env ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/ vue-tsc --noEmit && vite build && electron-builder",
    "preview": "vite preview",
    "electron:dev": "vite",
    "electron:build": "cross-env ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/ vue-tsc --noEmit && vite build && electron-builder --win && node scripts/cleanup-combined.js",
    "electron:build:all": "cross-env ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/ vue-tsc --noEmit && vite build && electron-builder --win --linux",
    "electron:build:mac": "cross-env ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/ vue-tsc --noEmit && vite build && electron-builder --mac",
    "electron:build:linux": "cross-env ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/ vue-tsc --noEmit && vite build && electron-builder --linux",
    "electron:build:win:x64": "cross-env ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/ vue-tsc --noEmit && vite build && electron-builder --win --x64",
    "electron:build:win:ia32": "cross-env ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/ vue-tsc --noEmit && vite build && electron-builder --win --ia32",
    "electron:build:win:arm64": "cross-env ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/ vue-tsc --noEmit && vite build && electron-builder --win --arm64",
    "electron:build:linux:x64": "cross-env ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/ vue-tsc --noEmit && vite build && electron-builder --linux --x64",
    "electron:build:linux:arm64": "cross-env ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/ vue-tsc --noEmit && vite build && electron-builder --linux --arm64",
    "electron:build:mac:x64": "cross-env ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/ vue-tsc --noEmit && vite build && electron-builder --mac --x64",
    "electron:build:mac:arm64": "cross-env ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/ vue-tsc --noEmit && vite build && electron-builder --mac --arm64",
    "electron:build:all:arch": "vue-tsc --noEmit && vite build && npm run electron:build:win:x64 && npm run electron:build:win:ia32 && npm run electron:build:linux:x64 && npm run electron:build:linux:arm64 && npm run electron:build:mac:arm64"
  },
  "dependencies": {
    "@milkdown/crepe": "^7.21.2",
    "@milkdown/kit": "^7.21.2",
    "@milkdown/vue": "^7.21.2",
    "adm-zip": "^0.5.17",
    "electron-store": "^7.0.0",
    "epubjs": "^0.3.93",
    "lucide-vue-next": "^0.263.0",
    "marked": "^9.0.0",
    "pinia": "^2.1.0",
    "sass": "^1.62.0",
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "cross-env": "^10.1.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^1.0.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vue-tsc": "^2.0.0"
  },
  "build": {
    "appId": "com.jianyue.reader",
    "productName": "简阅",
    "npmRebuild": false,
    "compression": "maximum",
    "asar": true,
    "asarUnpack": [
      "**/*.node"
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "!**/*.map",
      "dist-electron/**/*",
      "!**/*.map",
      "public/**/*",
      "!public/**/*.map"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"],
          "artifactName": "${productName} Setup ${version}-x64.${ext}"
        },
        {
          "target": "nsis",
          "arch": ["ia32"],
          "artifactName": "${productName} Setup ${version}-ia32.${ext}"
        },
        {
          "target": "nsis",
          "arch": ["arm64"],
          "artifactName": "${productName} Setup ${version}-arm64.${ext}"
        }
      ],
      "icon": "public/logo.png"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "public/logo.png"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/logo.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "简阅",
      "artifactName": "${productName} Setup ${version}-${arch}.${ext}"
    },
    "fileAssociations": [
      {
        "ext": "md",
        "name": "Markdown",
        "description": "Markdown 文档",
        "role": "Editor"
      },
      {
        "ext": "epub",
        "name": "EPUB",
        "description": "EPUB 电子书",
        "role": "Viewer"
      },
      {
        "ext": "txt",
        "name": "TXT",
        "description": "文本文档",
        "role": "Viewer"
      },
      {
        "ext": "mobi",
        "name": "MOBI",
        "description": "MOBI 电子书",
        "role": "Viewer"
      },
      {
        "ext": "azw3",
        "name": "AZW3",
        "description": "AZW3 电子书",
        "role": "Viewer"
      },
      {
        "ext": "cbz",
        "name": "CBZ",
        "description": "CBZ 漫画",
        "role": "Viewer"
      },
      {
        "ext": "cbr",
        "name": "CBR",
        "description": "CBR 漫画",
        "role": "Viewer"
      }
    ],
    "electronDownload": {
      "mirror": "https://npmmirror.com/mirrors/electron/"
    }
  }
}
